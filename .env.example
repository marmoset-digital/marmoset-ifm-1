# ===========================================
# MARMOSET HUB - Environment Variables
# ===========================================
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to version control

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gravity Forms Webhook ---
# Used to verify incoming webhooks are genuinely from your WordPress site
GF_WEBHOOK_SECRET=your-webhook-secret

# --- eWAY Payment Gateway ---
# Get these from your eWAY merchant portal
EWAY_API_KEY=your-eway-api-key
EWAY_API_PASSWORD=your-eway-api-password
EWAY_ENDPOINT=https://api.ewaypayments.com
# Use sandbox for testing:
# EWAY_ENDPOINT=https://api.sandbox.ewaypayments.com

# --- ServiceM8 ---
# OAuth credentials from ServiceM8 developer portal
SERVICEM8_CLIENT_ID=your-client-id
SERVICEM8_CLIENT_SECRET=your-client-secret
SERVICEM8_ACCESS_TOKEN=your-access-token
SERVICEM8_REFRESH_TOKEN=your-refresh-token

# --- Xero ---
# OAuth2 credentials from Xero developer portal
XERO_CLIENT_ID=your-client-id
XERO_CLIENT_SECRET=your-client-secret
XERO_TENANT_ID=your-tenant-id
XERO_ACCESS_TOKEN=your-access-token
XERO_REFRESH_TOKEN=your-refresh-token

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
MINIMUM_CREDIT_CARD_THRESHOLD=20000
